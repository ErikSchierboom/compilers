@page "/"
@using Gleamy

<PageTitle>Gleamy Playground</PageTitle>

<div class="playground-container">
    <div class="editor-section">
        <div class="section-header">
            <h3>Editor</h3>
            <button class="btn btn-primary" @onclick="ExecuteCode">Run (Ctrl+Enter)</button>
        </div>
        <textarea class="code-editor" 
                  @bind="_code" 
                  @bind:event="oninput"
                  @onkeydown="HandleKeyDown"
                  placeholder="Enter your Gleamy code here..."></textarea>
    </div>

    <div class="result-section">
        <h3>Result</h3>
        <div class="result-display">
            @if (_error != null)
            {
                <div class="alert alert-danger">
                    <pre>@_error</pre>
                </div>
            }
            else
            {
                <pre>@_result</pre>
            }
        </div>
    </div>
</div>

@code {
    private string _code = "let x = 10;\nlet y = 20;\nx + y";
    private string? _result;
    private string? _error;

    private void ExecuteCode()
    {
        _error = null;
        _result = null;

        if (string.IsNullOrWhiteSpace(_code))
        {
            return;
        }

        try
        {
            var output = Interpreter.Evaluate(_code);
            _result = output?.ToString() ?? "null";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e is { Key: "Enter", CtrlKey: true })
            ExecuteCode();
    }
}
